# Python compiled files — auto-generated, never commit these
__pycache__/
*.py[cod]

# Virtual environments — not needed, anyone can recreate from requirements.txt
diss_env/
venv/
.venv/

# Jupyter checkpoint files — auto-saved drafts, not your real work
.ipynb_checkpoints/

# TensorBoard logs — regenerated every training run, can be gigabytes
tb_logs/

# Trained model weights — too large for Git
models/*.zip

# macOS junk file — irrelevant on Linux but good practice
.DS_Store
build.log
